   "source": [
    "# DS-TGNN V1.1: Research-Paper Evaluation Report\n",
    "\n",
    "This notebook serves as an orchestration layer for the DS-TGNN experimental pipeline. It imports the latest architectural and training logic directly from the project's source files to ensure results are always in sync with the latest code state.\n",
    "\n",
    "### Core Pipeline Components:\n",
    "1. **Architecture**: Diffusion Denoiser → LSTM → GNN → MLP (V1.1 Modular).\n",
    "2. **Data Model**: 180-day window, 30-day horizon, with 30-day chronological embargo.\n",
    "3. **Evaluations**: Monte-Carlo Dropout uncertainty, Magnitude-Weighted loss, and Trading IR.\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 📦 SETUP & VERIFICATION ---\n",
    "import os\n",
    "import sys\n",
    "import torch\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Ensure local package modules are discoverable\n",
    "root_dir = os.getcwd()\n",
    "sys.path.append(root_dir)\n",
    "sys.path.append(os.path.join(root_dir, 'models'))\n",
    "sys.path.append(os.path.join(root_dir, 'models', 'diffusion'))\n",
    "sys.path.append(os.path.join(root_dir, 'models', 'base'))\n",
    "\n",
    "# Source of Truth Imports\n",
    "try:\n",
    "    from models.dataset import get_dataloaders\n",
    "    from models.ds_tgnn import DiffusionReturnPrediction\n",
    "    from diffusion.diffusion_architecture import Diffusion\n",
    "    from evaluate_experiments import run_experiment, calculate_metrics\n",
    "except ImportError as e:\n",
    "    print(f\"❌ Import failed: {e}\")\n",
    "    print(\"Verify you are running the notebook from the root directory.\")\n",
    "    raise\n",
    "\n",
    "print(\"✅ Notebook successfully synced with local .py logic.\")\n",
    "print(f\"- Dataset Module: {get_dataloaders.__module__}\")\n",
    "print(f\"- Model Module:   {DiffusionReturnPrediction.__module__}\")\n",
    "print(f\"- GPU Available:  {torch.cuda.is_available()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "020d10d7",
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 🧪 STEP 1: CONFIGURE & EXECUTE V1.1 ---\n",
    "print(\"🚀 Initializing V1.1 Production Configuration...\")\n",
    "\n",
    "config = {\n",
    "    \"name\": \"Full_V1.1_Walkthrough\",\n",
    "    \"epochs\": 5,          # Fast run for demo purposes\n",
    "    \"lr\": 0.001,\n",
    "    \"batch_size\": 16,\n",
    "    \"mc_samples\": 20,     # Enable MC-Dropout for uncertainty\n",
    "    \"use_embargo\": True,\n",
    "    \"mag_weighted\": True,\n",
    "    \"use_diffusion\": True,\n",
    "    \"use_lstm\": True,\n",
    "    \"use_gnn\": True\n",
    "}\n",
    "\n",
    "# Execute Training & Inference using centralized script logic\n",
    "results, history, preds, targets, stds = run_experiment(config)\n",
    "\n",
    "print(\"\\n🏁 Walkthrough Run Complete.\")\n",
    "for metric, value in results.items():\n",
    "    if isinstance(value, (float, int)):\n",
    "        print(f\"{metric:15}: {value:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ca67ed50",
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 📈 STEP 2: ANALYTIC PLOTTING ---\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# 1. Learning Curves\n",
    "axes[0].plot(history['train_loss'], label='Train (Weighted MSE)')\n",
    "axes[0].plot(history['val_loss'], label='Validation (MSE)')\n",
    "axes[0].set_title(\"Phase 1: Model Convergence\")\n",
    "axes[0].set_xlabel(\"Epoch\")\n",
    "axes[0].set_ylabel(\"Loss\")\n",
    "axes[0].legend()\n",
    "\n",
    "# 2. Uncertainty Calibration (MC-Dropout Std vs realized Absolute Error)\n",
    "if stds is not None:\n",
    "    abs_err = np.abs(preds - targets).ravel()\n",
    "    uncertainty = stds.ravel()\n",
    "    axes[1].scatter(uncertainty, abs_err, alpha=0.3, color='purple')\n",
    "    axes[1].set_title(\"Phase 2: Uncertainty vs Realized Error\")\n",
    "    axes[1].set_xlabel(\"Predicted Uncertainty (MC-Dropout Std)\")\n",
    "    axes[1].set_ylabel(\"Absolute Prediction Error\")\n",
    "    \n",
    "    # Trendline for correlation\n",
    "    z = np.polyfit(uncertainty, abs_err, 1)\n",
    "    p = np.poly1d(z)\n",
    "    axes[1].plot(uncertainty, p(uncertainty), \"r--\", alpha=0.8)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }\n",
 ],
